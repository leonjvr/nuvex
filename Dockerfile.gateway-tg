FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml ./
RUN uv pip install --system --no-cache "python-telegram-bot>=21.0" "fastapi>=0.115" "uvicorn[standard]>=0.32" "httpx>=0.27"

COPY src/gateway ./src/gateway
COPY src/shared ./src/shared

ENV GATEWAY_TG_PORT=8102
EXPOSE 8102

CMD ["python", "-m", "src.gateway.telegram.server"]
