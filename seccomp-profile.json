{
  "_comment": "SIDJUA Docker seccomp profile. Allows standard syscalls plus those required by bubblewrap (unshare, clone, mount, pivot_root). Explicitly blocks dangerous SYS_ADMIN-exclusive syscalls that bubblewrap does not need.",
  "defaultAction": "SCMP_ACT_ALLOW",
  "syscalls": [
    {
      "names": [
        "keyctl",
        "add_key",
        "request_key",
        "reboot",
        "swapon",
        "swapoff",
        "sysfs",
        "kexec_load",
        "kexec_file_load",
        "nfsservctl",
        "_sysctl",
        "uselib",
        "ustat",
        "create_module",
        "init_module",
        "finit_module",
        "delete_module",
        "ioperm",
        "iopl",
        "modify_ldt"
      ],
      "action": "SCMP_ACT_ERRNO"
    }
  ]
}
