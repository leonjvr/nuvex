{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SIDJUA",
  "version": "1.0.0",
  "identifier": "com.sidjua.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SIDJUA — Agent Governance Platform",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' http://localhost:3000 http://127.0.0.1:3000 http://localhost:4200 http://127.0.0.1:4200; frame-ancestors 'none'; form-action 'self'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "copyright": "© 2026 Götz Kohlberg — AGPL-3.0-only",
    "longDescription": "SIDJUA Desktop — native monitoring and governance dashboard for the SIDJUA AI agent governance platform. Connect to a running SIDJUA server to view agents, tasks, audit logs, costs, and governance status in real time.",
    "shortDescription": "SIDJUA agent governance dashboard",
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "hardenedRuntime": true
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
