[Unit]
Description=SIDJUA AI Governance Platform
Documentation=https://github.com/GoetzKohlberg/sidjua
After=network.target
Wants=network.target

[Service]
Type=notify
User=sidjua
Group=sidjua
WorkingDirectory=/opt/sidjua
ExecStart=/usr/bin/node /opt/sidjua/dist/index.js start
ExecStop=/bin/kill -s SIGTERM $MAINPID
Restart=on-failure
RestartSec=5s
TimeoutStartSec=30
TimeoutStopSec=30
WatchdogSec=30

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/sidjua/data /opt/sidjua/logs

# Resource limits
LimitNOFILE=65536
MemoryMax=2G

# Environment
EnvironmentFile=-/etc/sidjua/env

[Install]
WantedBy=multi-user.target
