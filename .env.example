# SIDJUA Configuration
# Copy to .env and customize

# Server
SIDJUA_PORT=3000
SIDJUA_HOST=0.0.0.0
NODE_ENV=production

# Data Directories (Docker defaults — change for manual install)
SIDJUA_DATA_DIR=./data
SIDJUA_CONFIG_DIR=./config
SIDJUA_LOG_DIR=./logs

# Qdrant (Vector Database)
SIDJUA_QDRANT_URL=http://localhost:6333

# LLM Providers (configure at least one)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=...
# CLOUDFLARE_ACCOUNT_ID=...
# CLOUDFLARE_API_TOKEN=...

# API Authentication
# Generate with: sidjua api-key generate
# SIDJUA_API_KEY=
