# Channel Credentials
# Copy this file to .secrets/channels.env and fill in your values.
# This file is tracked; .secrets/channels.env is gitignored.

# ── Telegram ────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to message the agent
TELEGRAM_ALLOWED_USERS=

# ── Email (IMAP/SMTP) ────────────────────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Slack ────────────────────────────────────────────────────────────────
# Get from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# ── Discord ──────────────────────────────────────────────────────────────
# Get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_WEBHOOK_URL=
