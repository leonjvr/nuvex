# Infrastructure Secrets
# Copy this file to .secrets/infra.env and fill in your values.
# This file is tracked; .secrets/infra.env is gitignored.

# Hetzner Cloud API token (dev project)
HETZNER_DEV_PROJECT_API=

# PostgreSQL connection string (overrides database.url in nuvex.yaml)
# DATABASE_URL=postgresql://user:password@localhost:9432/nuvex

# Fernet key for encrypting agent skill environment variables
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NUVEX_SECRET_KEY=

# Dashboard API key (operator access)
# Generate: openssl rand -hex 32
NUVEX_API_KEY=
