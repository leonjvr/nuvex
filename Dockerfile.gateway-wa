FROM node:20-slim

WORKDIR /app

COPY src/gateway/whatsapp/package.json ./
# node_modules pre-built on host (Baileys has SSH-only GitHub deps — see README)
COPY src/gateway/whatsapp/node_modules ./node_modules
COPY src/gateway/whatsapp/src ./src

ENV GATEWAY_WA_PORT=8101
EXPOSE 8101

CMD ["node", "src/index.js"]
