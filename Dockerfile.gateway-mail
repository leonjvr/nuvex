FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml ./
RUN uv pip install --system --no-cache "aiosmtplib>=3.0" "aioimaplib>=1.1" "fastapi>=0.115" "uvicorn[standard]>=0.32" "httpx>=0.27"

COPY src/gateway ./src/gateway
COPY src/shared ./src/shared

ENV GATEWAY_MAIL_PORT=8103
EXPOSE 8103

CMD ["python", "-m", "src.gateway.email.server"]
