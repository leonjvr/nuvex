# NUVEX Gateway Credentials
# Copy this file to channels.env and fill in your values.
# docker-compose.local.yml loads this file automatically for gateway containers.

# ── Telegram ────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs that are allowed to message the agent.
# Leave empty to allow everyone (not recommended for production).
TELEGRAM_ALLOWED_USERS=

# ── WhatsApp ─────────────────────────────────────────────────────────────
# Which agent handles incoming WhatsApp messages (must match agents in nuvex.yaml).
NUVEX_AGENT_ID=maya

# DM policy: "pairing" = only paired/known numbers, "open" = anyone
WA_DM_POLICY=pairing

# Group policy: "allowlist" = only explicitly allowed groups, "open" = any group
WA_GROUP_POLICY=allowlist

# ── Email (IMAP/SMTP) ─────────────────────────────────────────────────────
# Set these if you have the email gateway enabled for an agent in nuvex.yaml.
# EMAIL_USER=
# EMAIL_PASS=
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
